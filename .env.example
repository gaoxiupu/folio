# ── Required ──────────────────────────────────────────────────────────────────
# Volcengine Ark API key — used for both chat and embeddings
ARK_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
# Base URL of this server (used to build the widget <script> src)
# Defaults to http://localhost:3000 in development
NEXT_PUBLIC_BASE_URL=

# ── Abuse Prevention ──────────────────────────────────────────────────────────
# Per-IP rate limits for /api/chat
RATE_LIMIT_PER_MINUTE=10        # max requests per IP per minute (default: 10)
RATE_LIMIT_PER_DAY=100          # max requests per IP per day (default: 100)

# Daily global API call budget (protects against cost drain)
DAILY_API_BUDGET=500            # max total chat requests per day (default: 500)

# Allowed origins for API requests (comma-separated)
# The server's own NEXT_PUBLIC_BASE_URL is always allowed.
ALLOWED_ORIGINS=                # e.g., https://myportfolio.com

# Domains allowed to embed the widget (CSP frame-ancestors)
# Use * to allow any domain (default), or list specific domains.
ALLOWED_EMBED_DOMAINS=*         # e.g., 'self' https://myportfolio.com

# ── GitHub integration (optional) ─────────────────────────────────────────────
# Personal access token (optional) — raises GitHub public API rate limit
# from 60 to 5000 requests/hour. Only needs public_repo read scope.
GITHUB_TOKEN=
